# App
APP_ENV=dev
APP_CORS_ORIGINS=http://localhost:5173
APP_FRONTEND_BASE=http://localhost:5173
APP_TIMEZONE=Asia/Bishkek
APP_COOKIE_SECURE=false
APP_COOKIE_SAMESITE=lax

# JWT
APP_JWT_SECRET=change-me
APP_JWT_ACCESS_MINUTES=15
APP_JWT_REFRESH_DAYS=30

# Encryption key for storing OAuth tokens (Fernet key)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=change-me

# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Zoom OAuth (user-level)
ZOOM_CLIENT_ID=YOUR_ZOOM_CLIENT_ID
ZOOM_CLIENT_SECRET=YOUR_ZOOM_CLIENT_SECRET
ZOOM_REDIRECT_URI=http://localhost:8000/api/zoom/oauth/callback
